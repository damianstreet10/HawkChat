{
  "name": "hawkchat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0",
    "dev:fresh": "rm -rf .next && next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "start:lan": "next start -H 0.0.0.0",
    "lint": "next lint",
    "build:seed": "tsx scripts/build-seed-db.ts",
    "generate:pdfs": "tsx scripts/generate-demo-pdfs.ts",
    "setup:lan": "npm run generate:pdfs && echo 'Add OPENAI_API_KEY to .env then: npm run dev:lan'"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "next": "^14.2.28",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.24",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.28",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
