# Required for chat and embeddings (NotebookLM-style grounded Q&A)
OPENAI_API_KEY=sk-...

# Optional: use a different chat model
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Site-wide password (login page before notebooks). Leave unset for open LAN demo.
# HAWKCHAT_SITE_PASSWORD=change-me

# --- Monitor accounts (guests stay anonymous; monitors see /admin/activity) ---
# Comma-separated email:token pairs — pre-approved only, no self-signup
# HAWKCHAT_MONITORS=ops@company.com:long-secret-token,lead@company.com:other-token

# --- Access control (view-only vs upload) ---
# Set to true to require sign-in for all users (optional; LAN demo usually false)
HAWKCHAT_REQUIRE_AUTH=false

# Admins for /login/staff (comma-separated email:token — only one HAWKCHAT_ADMIN_EMAIL if you prefer)
# HAWKCHAT_ADMINS=you@example.com:long-admin-token,other@example.com:other-token
HAWKCHAT_ADMIN_EMAIL=you@example.com
HAWKCHAT_ADMIN_TOKEN=change-me-to-a-long-random-string

# LAN demo (10.0.2.x): preload PDFs + show share URL on home page
HAWKCHAT_AUTO_SEED=false
HAWKCHAT_LAN_DEMO=false
NEXT_PUBLIC_HAWKCHAT_LAN_DEMO=false
# Full IPv4 (four numbers), e.g. http://192.168.68.173:3000 — or leave wrong/empty and the home page auto-detects
NEXT_PUBLIC_HAWKCHAT_LAN_URL=http://10.0.2.40:3000
# Notebooks are defined in seed/manifest.json (useful-resources, hardware-support, …)

# --- Events (tournament spaces — separate from LAN demo at /) ---
# Auto-register events from seed/events/{slug}/manifest.json on startup.
# Event-only users (viewer role): slug:email:token pairs, comma-separated.
# HAWKCHAT_EVENT_USERS=champions-league:test@hawkeyeinnovations.com:TEST

# --- Kit Quirks resolution emails (sent when admin marks a report Resolved) ---
# From/Reply-To use the signed-in staff member's email; SMTP must allow sending as that address.
# HAWKCHAT_SMTP_HOST=smtp.office365.com
# HAWKCHAT_SMTP_PORT=587
# HAWKCHAT_SMTP_SECURE=false
# HAWKCHAT_SMTP_USER=notifications@yourcompany.com
# HAWKCHAT_SMTP_PASS=your-app-password-or-smtp-secret

# New Kit Quirk alerts (optional — configure when ready)
# Slack/Teams-compatible incoming webhook:
# HAWKCHAT_QUIRK_WEBHOOK_URL=https://hooks.slack.com/services/...
# Comma-separated staff emails (uses SMTP above):
# HAWKCHAT_QUIRK_NOTIFY_EMAIL=ops@yourcompany.com,support@yourcompany.com
# HAWKCHAT_QUIRK_NOTIFY_FROM=notifications@yourcompany.com
